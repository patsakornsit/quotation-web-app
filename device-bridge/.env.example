# Example .env for the bridge
# The cloud OpenClaw or DeepSeek endpoint that accepts { command, params }
DEEPSEEK_API_URL=https://api.deepseek.example/command
# Optional API key (Bearer)
DEEPSEEK_API_KEY=

# Port the bridge will listen on
PORT=3001

# Microsoft SQL Server connection (SQL authentication)
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=QuotationApp
SQL_USER=quotation_app
SQL_PASSWORD=change-this-password
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true

# For a named instance such as SQLEXPRESS, set SQL_INSTANCE and leave SQL_PORT unused.
# SQL_INSTANCE=SQLEXPRESS
