# DeepSeek quotation assistant (OpenAI-compatible chat-completions API)
DEEPSEEK_CHAT_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Port the bridge will listen on
PORT=3001

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_TOKEN_TTL_SECONDS=43200

# Microsoft SQL Server Express using Windows Authentication (for .\SQLEXPRESS)
SQL_SERVER=localhost
SQL_INSTANCE=SQLEXPRESS
SQL_DATABASE=QuotationApp
SQL_AUTHENTICATION=windows
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true

# For SQL authentication instead, use:
# SQL_AUTHENTICATION=sql
# SQL_USER=quotation_app
# SQL_PASSWORD=change-this-password
# SQL_PORT=1433
